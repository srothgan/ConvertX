{
  "name": "convertx",
  "version": "0.17.0",
  "scripts": {
    "dev": "bun run backend:dev",
    "hot": "bun run backend:hot",
    "backend:dev": "bun run --watch backend/index.ts",
    "backend:hot": "bun run --hot backend/index.ts",
    "backend:build": "npm-run-all --serial clean:backend backend:compile",
    "backend:compile": "tsc",
    "backend:typecheck": "tsc --noEmit",
    "frontend:dev": "bun run --cwd frontend dev",
    "frontend:build": "npm-run-all --serial clean:frontend frontend:compile",
    "frontend:compile": "bun run --cwd frontend build",
    "frontend:typecheck": "bun run --cwd frontend typecheck",
    "clean": "npm-run-all --parallel clean:backend clean:frontend",
    "clean:backend": "bun -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "clean:frontend": "bun -e \"import { rmSync } from 'node:fs'; rmSync('frontend/build', { recursive: true, force: true })\"",
    "format": "npm-run-all 'format:*'",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "test": "bun test",
    "build:js": "bun run backend:build",
    "build": "npm-run-all --serial frontend:build backend:build",
    "verify": "npm-run-all --serial verify:typecheck verify:test verify:lint verify:deps verify:format build",
    "verify:typecheck": "npm-run-all --parallel backend:typecheck frontend:typecheck",
    "verify:test": "bun test",
    "verify:lint": "eslint .",
    "verify:deps": "knip",
    "verify:format": "prettier --check .",
    "lint": "npm-run-all 'lint:*'",
    "lint:tsc": "bun run backend:typecheck",
    "lint:knip": "knip",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check ."
  },
  "dependencies": {
    "@elysiajs/static": "^1.4.7",
    "elysia": "1.4.22",
    "sanitize-filename": "^1.6.4",
    "tar": "^7.5.13"
  },
  "module": "backend/index.ts",
  "type": "module",
  "bun-create": {
    "start": "bun run backend/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "knip": "^5.88.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "trustedDependencies": [
    "oxc-resolver"
  ]
}
